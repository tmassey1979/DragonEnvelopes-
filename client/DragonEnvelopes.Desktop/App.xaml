<Application x:Class="DragonEnvelopes.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:DragonEnvelopes.Desktop.ViewModels"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#0E111B" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#141B2D" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#1C2740" />
        <SolidColorBrush x:Key="PanelOutlineBrush" Color="#2D3F68" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F2F6FF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B9C6E6" />

        <DataTemplate DataType="{x:Type viewModels:ShellContentViewModel}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{Binding Title}"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="30"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding Description}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,24,0,0"
                        CornerRadius="18"
                        Padding="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelOutlineBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{Binding EmptyStateTitle}"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding EmptyStateBody}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Application.Resources>
</Application>
