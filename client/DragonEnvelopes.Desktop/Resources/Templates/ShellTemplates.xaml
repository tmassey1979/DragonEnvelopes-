                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding MonthlyBudgetDisplay}"
                                                   Style="{StaticResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CurrentBalanceDisplay}"
                                                   Style="{StaticResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding IsArchived, StringFormat=Archived: {0}}"
                                                   Style="{StaticResource CaptionTextStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </controls:CardControl>

                <controls:CardControl Grid.Column="2"
                                      Header="{Binding EditorTitle}"
                                      Subheader="Create and maintain envelope details"
