<Window x:Class="DragonEnvelopes.Desktop.Views.CreateFamilyAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Create Family Account"
        Width="520"
        Height="600"
        MinWidth="460"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource ShellBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="22">
        <Border Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="14"
                Padding="22"
                BorderBrush="{StaticResource PanelOutlineBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Create Family Account"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Margin="0,6,0,16"
                               Style="{StaticResource CaptionTextStyle}"
                               Text="Set up your household workspace in DragonEnvelopes." />
                </StackPanel>

                <StackPanel Grid.Row="1" KeyboardNavigation.TabNavigation="Cycle">
                    <Label Content="_Family Name"
                           Target="{Binding ElementName=FamilyNameBox}" />
                    <TextBox x:Name="FamilyNameBox"
                             Margin="0,8,0,12"
                             AutomationProperties.Name="Family Name" />

                    <TextBlock Text="Primary Guardian Name" />
                    <Grid Margin="0,8,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="GuardianFirstNameBox"
                                 Grid.Column="0"
                                 ToolTip="First Name"
                                 AutomationProperties.Name="Primary Guardian First Name" />
                        <TextBox x:Name="GuardianLastNameBox"
                                 Grid.Column="2"
                                 ToolTip="Last Name"
                                 AutomationProperties.Name="Primary Guardian Last Name" />
                    </Grid>

                    <Label Content="_Email"
                           Target="{Binding ElementName=EmailBox}" />
                    <TextBox x:Name="EmailBox"
                             Margin="0,8,0,12"
                             AutomationProperties.Name="Email" />

                    <Label Content="_Password"
                           Target="{Binding ElementName=PasswordBox}" />
                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,8,0,12"
                                 AutomationProperties.Name="Password" />

                    <Label Content="_Confirm Password"
                           Target="{Binding ElementName=ConfirmPasswordBox}" />
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Margin="0,8,0,0"
                                 AutomationProperties.Name="Confirm Password" />

                    <TextBlock x:Name="ValidationText"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource AccentBrush}"
                               Visibility="Collapsed"
                               TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Polite" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="0,16,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button MinWidth="88"
                            Margin="0,0,10,0"
                            Content="Cancel"
                            IsCancel="True"
                            AutomationProperties.Name="Cancel create family account"
                            Click="OnCancelClicked" />
                    <Button x:Name="CreateButton"
                            MinWidth="124"
                            Content="Create Account"
                            IsDefault="True"
                            AutomationProperties.Name="Create family account"
                            Click="OnCreateClicked" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
