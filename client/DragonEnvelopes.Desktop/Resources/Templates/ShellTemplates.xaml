<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:DragonEnvelopes.Desktop.Controls"
                    xmlns:viewModels="clr-namespace:DragonEnvelopes.Desktop.ViewModels">
    <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dashboard" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Net worth, balances, and recent activity health at a glance."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Content="Reload"
                        Command="{Binding LoadCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <controls:CardControl Grid.Row="0"
                                      Header="Budget KPI Cards"
                                      Subheader="Current financial health snapshot"
                                      EmptyMessage="No KPI data returned."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="{Binding IsEmpty}">
                    <ItemsControl ItemsSource="{Binding KpiCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel ItemWidth="220" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:MetricTileViewModel}">
                                <controls:MetricTileControl Margin="0,0,14,14"
                                                            Label="{Binding Label}"
                                                            Value="{Binding Value}"
                                                            Trend="{Binding Trend}"
                                                            TrendDirection="{Binding TrendDirection}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:CardControl>

                <controls:CardControl Grid.Row="1"
                                      Margin="0,14,0,0"
                                      Header="Recent Transactions"
                                      Subheader="Most recent posted activity"
                                      EmptyMessage="No recent transactions found."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="{Binding IsEmpty}">
                    <ItemsControl ItemsSource="{Binding RecentTransactions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:TransactionRowViewModel}">
                                <controls:TransactionRowControl Date="{Binding Date}"
                                                                Merchant="{Binding Merchant}"
                                                                Amount="{Binding Amount}"
                                                                Envelope="{Binding Envelope}"
                                                                Category="{Binding Category}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:ShellContentViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="{Binding Title}" Style="{StaticResource DisplayTextStyle}" />
                <TextBlock Margin="0,8,0,0"
                           Text="{Binding Description}"
                           Style="{StaticResource BodyTextStyle}" />
            </StackPanel>

            <ItemsControl Grid.Row="1" Margin="0,20,0,0" ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="220" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:MetricTileViewModel}">
                        <controls:MetricTileControl Margin="0,0,14,14"
                                                    Label="{Binding Label}"
                                                    Value="{Binding Value}"
                                                    Trend="{Binding Trend}"
                                                    TrendDirection="{Binding TrendDirection}"
                                                    IsLoading="{Binding IsLoading}"
                                                    IsEmpty="{Binding IsEmpty}"
                                                    EmptyMessage="{Binding EmptyMessage}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <controls:CardControl Grid.Row="2"
                                  Margin="0,8,0,0"
                                  Header="{Binding EmptyStateTitle}"
                                  Subheader="Primary content region"
                                  EmptyMessage="{Binding EmptyStateBody}"
                                  IsLoading="{Binding IsLoading}"
                                  IsEmpty="{Binding IsEmpty}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,14"
                            Padding="14"
                            CornerRadius="10"
                            Background="{StaticResource PanelMutedBackgroundBrush}"
                            BorderBrush="{StaticResource PanelOutlineBrush}"
                            BorderThickness="1">
                        <TextBlock Text="This reusable Card wraps workspace content and centralizes loading/empty visuals. Envelope tiles below are reusable controls with hover/focus/selected states."
                                   Style="{StaticResource BodyTextStyle}" />
                    </Border>

                    <StackPanel Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Envelopes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="220" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:EnvelopeTileViewModel}">
                                    <controls:EnvelopeTileControl EnvelopeName="{Binding Name}"
                                                                  MonthlyBudget="{Binding MonthlyBudget}"
                                                                  CurrentBalance="{Binding CurrentBalance}"
                                                                  IsSelected="{Binding IsSelected}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ListBox Margin="0,4,0,0"
                                 ItemsSource="{Binding Transactions}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Focusable" Value="False" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:TransactionRowViewModel}">
                                    <controls:TransactionRowControl Date="{Binding Date}"
                                                                    Merchant="{Binding Merchant}"
                                                                    Amount="{Binding Amount}"
                                                                    Envelope="{Binding Envelope}"
                                                                    Category="{Binding Category}"
                                                                    IsSelected="{Binding IsSelected}"
                                                                    IsEdited="{Binding IsEdited}"
                                                                    IsFlagged="{Binding IsFlagged}"
                                                                    EditCommand="{Binding EditCommand}"
                                                                    SplitCommand="{Binding SplitCommand}"
                                                                    CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>
            </controls:CardControl>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:AccountsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Accounts" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Connected account balances and source-of-truth list."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Content="Reload"
                        Command="{Binding LoadCommand}" />
                <Button Grid.Column="2"
                        VerticalAlignment="Center"
                        Content="Add Account"
                        Command="{Binding SaveAccountCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <controls:CardControl Grid.Row="2"
                                  Margin="0,12,0,0"
                                  Header="Account List"
                                  Subheader="Scaffold with API-bound loading and error handling"
                                  EmptyMessage="No accounts found for this family yet."
                                  IsLoading="{Binding IsLoading}"
                                  IsEmpty="{Binding IsEmpty}">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:AccountListItemViewModel}">
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        CornerRadius="10"
                                        Background="{StaticResource PanelMutedBackgroundBrush}"
                                        BorderBrush="{StaticResource PanelOutlineBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Type}" Style="{StaticResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Balance}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Margin="0,12,0,0"
                            Padding="12"
                            CornerRadius="10"
                            Background="{StaticResource PanelMutedBackgroundBrush}"
                            BorderBrush="{StaticResource PanelOutlineBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding EditorMessage}" Style="{StaticResource CaptionTextStyle}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,6" Text="Name" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,6" Text="Type" Style="{StaticResource CaptionTextStyle}" />
                                    <ComboBox ItemsSource="{Binding AccountTypeOptions}"
                                              SelectedItem="{Binding DraftType, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Margin="0,0,0,6" Text="Opening Balance" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftOpeningBalance, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                <Button Margin="0,0,8,0"
                                        Content="Create Account"
                                        Command="{Binding SaveAccountCommand}" />
                                <Button Content="Reset"
                                        Command="{Binding ResetAccountDraftCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </controls:CardControl>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:BudgetsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Budgets" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Allocation visualization by month and envelope coverage."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <TextBox Grid.Column="1"
                         Margin="12,0,8,0"
                         VerticalAlignment="Center"
                         ToolTip="Budget month (yyyy-MM)"
                         Text="{Binding SelectedMonth, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Grid.Column="2"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          Content="Include Archived"
                          IsChecked="{Binding IncludeArchived}" />
                <Button Grid.Column="3"
                        VerticalAlignment="Center"
                        Content="Apply"
                        Command="{Binding ApplyFiltersCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <controls:CardControl Grid.Row="2"
                                  Margin="0,12,0,0"
                                  Header="Budget Allocation"
                                  Subheader="{Binding MonthDisplay, StringFormat=Month: {0}}"
                                  EmptyMessage="No budget/allocation data for the selected month."
                                  IsLoading="{Binding IsLoading}"
                                  IsEmpty="{Binding IsEmpty}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <WrapPanel>
                            <Border Margin="0,0,12,12"
                                    Padding="12"
                                    Width="200"
                                    CornerRadius="10"
                                    Background="{StaticResource PanelMutedBackgroundBrush}"
                                    BorderBrush="{StaticResource PanelOutlineBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Total Income" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding TotalIncomeDisplay}" Style="{StaticResource BodyTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,12,12"
                                    Padding="12"
                                    Width="200"
                                    CornerRadius="10"
                                    Background="{StaticResource PanelMutedBackgroundBrush}"
                                    BorderBrush="{StaticResource PanelOutlineBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Allocated" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding AllocatedDisplay}" Style="{StaticResource BodyTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,12,12"
                                    Padding="12"
                                    Width="200"
                                    CornerRadius="10"
                                    Background="{StaticResource PanelMutedBackgroundBrush}"
                                    BorderBrush="{StaticResource PanelOutlineBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Remaining" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding RemainingDisplay}" Style="{StaticResource BodyTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,12,12"
                                    Padding="12"
                                    Width="220"
                                    CornerRadius="10"
                                    Background="{StaticResource PanelMutedBackgroundBrush}"
                                    BorderBrush="{StaticResource PanelOutlineBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Allocation Coverage" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding AllocationPercentDisplay}" Style="{StaticResource BodyTextStyle}" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Margin="0,0,0,4"
                                Padding="12"
                                CornerRadius="10"
                                Background="{StaticResource PanelMutedBackgroundBrush}"
                                BorderBrush="{StaticResource PanelOutlineBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding BudgetEditorMessage}" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Margin="0,8,0,4" Text="Total Income" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Width="240"
                                             Text="{Binding DraftTotalIncome, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Bottom"
                                        Content="{Binding BudgetActionLabel}"
                                        Command="{Binding SaveBudgetCommand}" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              Margin="0,8,0,0"
                              ItemsSource="{Binding EnvelopeAllocations}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              RowHeight="34"
                              GridLinesVisibility="Horizontal"
                              Background="{StaticResource PanelMutedBackgroundBrush}"
                              BorderBrush="{StaticResource PanelOutlineBrush}"
                              BorderThickness="1"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Envelope" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Monthly Budget" Binding="{Binding MonthlyBudget}" Width="140" />
                            <DataGridTextColumn Header="Current Balance" Binding="{Binding CurrentBalance}" Width="140" />
                            <DataGridTextColumn Header="% of Income" Binding="{Binding AllocationPercent}" Width="110" />
                            <DataGridTextColumn Header="% of Envelope Left" Binding="{Binding BalancePercent}" Width="130" />
                            <DataGridCheckBoxColumn Header="Archived" Binding="{Binding IsArchived}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </controls:CardControl>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:TransactionsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Transactions" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Transaction feed with filters plus split-aware create form."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <ComboBox Grid.Column="1"
                          Margin="12,0,8,0"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                          DisplayMemberPath="Name" />
                <TextBox Grid.Column="2"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         ToolTip="Filter by merchant or description"
                         Text="{Binding MerchantFilter, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="3"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         ToolTip="Filter by category"
                         Text="{Binding CategoryFilter, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="4"
                        VerticalAlignment="Center"
                        Content="Reload"
                        Command="{Binding ReloadTransactionsCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <controls:CardControl Grid.Column="0"
                                      Header="Transaction Grid"
                                      Subheader="{Binding SortIndicator}"
                                      EmptyMessage="No transactions match current filters."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="{Binding IsEmpty}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Content="Sort Date"
                                    Command="{Binding SortByCommand}"
                                    CommandParameter="Date" />
                            <Button Margin="0,0,8,0"
                                    Content="Sort Merchant"
                                    Command="{Binding SortByCommand}"
                                    CommandParameter="Merchant" />
                            <Button Margin="0,0,8,0"
                                    Content="Sort Amount"
                                    Command="{Binding SortByCommand}"
                                    CommandParameter="Amount" />
                            <Button Margin="0,0,8,0"
                                    Content="Sort Category"
                                    Command="{Binding SortByCommand}"
                                    CommandParameter="Category" />
                            <CheckBox VerticalAlignment="Center"
                                      Content="Include Uncategorized"
                                      IsChecked="{Binding IncludeUncategorized}" />
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  Margin="0,12,0,0"
                                  ItemsSource="{Binding Transactions}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  RowHeight="34"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource PanelMutedBackgroundBrush}"
                                  BorderBrush="{StaticResource PanelOutlineBrush}"
                                  BorderThickness="1"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding OccurredDateDisplay}" Width="110" />
                                <DataGridTextColumn Header="Merchant" Binding="{Binding Merchant}" Width="180" />
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                                <DataGridTextColumn Header="Envelope" Binding="{Binding Envelope}" Width="140" />
                                <DataGridTextColumn Header="Category" Binding="{Binding CategoryDisplay}" Width="140" />
                                <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </controls:CardControl>

                <controls:CardControl Grid.Column="2"
                                      Header="Create Transaction"
                                      Subheader="Supports single envelope or split entries"
                                      EmptyMessage="Editor unavailable."
                                      IsLoading="False"
                                      IsEmpty="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding EditorStatusMessage}" Style="{StaticResource CaptionTextStyle}" />

                            <TextBlock Margin="0,14,0,6" Text="Merchant" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftMerchant, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,14,0,6" Text="Description" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftDescription, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,6" Text="Amount" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftAmount, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,6" Text="Occurred On (yyyy-MM-dd)" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftOccurredOn, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Margin="0,14,0,6" Text="Category (optional)" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftCategory, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,14,0,6" Text="Envelope" Style="{StaticResource CaptionTextStyle}" />
                            <ComboBox ItemsSource="{Binding Envelopes}"
                                      SelectedValue="{Binding DraftEnvelopeId, Mode=TwoWay}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name" />

                            <CheckBox Margin="0,14,0,0"
                                      Content="Use split editor"
                                      IsChecked="{Binding UseSplitEditor}" />

                            <StackPanel Margin="0,10,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UseSplitEditor}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <Border Padding="10"
                                        CornerRadius="8"
                                        Background="{StaticResource PanelMutedBackgroundBrush}"
                                        BorderBrush="{StaticResource PanelOutlineBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center"
                                                       Text="{Binding SplitTotal, StringFormat=Split Total: {0:C2}}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                            <TextBlock Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding DraftAmount, StringFormat=Target: {0:C2}}"
                                                       Style="{StaticResource CaptionTextStyle}" />
                                            <TextBlock Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="(must match)">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#A3A3A3" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSplitTotalValid}" Value="False">
                                                                <Setter Property="Foreground" Value="#EE4444" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <ItemsControl Margin="0,10,0,0"
                                                      ItemsSource="{Binding SplitDrafts}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:TransactionSplitDraftViewModel}">
                                                    <Border Margin="0,0,0,8"
                                                            Padding="10"
                                                            CornerRadius="8"
                                                            Background="#171717"
                                                            BorderBrush="{StaticResource PanelOutlineBrush}"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="1.3*" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <ComboBox Grid.Column="0"
                                                                      Margin="0,0,8,0"
                                                                      ItemsSource="{Binding DataContext.Envelopes, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                      SelectedValue="{Binding EnvelopeId, Mode=TwoWay}"
                                                                      SelectedValuePath="Id"
                                                                      DisplayMemberPath="Name" />
                                                            <TextBox Grid.Column="1"
                                                                     Margin="0,0,8,0"
                                                                     Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" />
                                                            <TextBox Grid.Column="2"
                                                                     Margin="0,0,8,0"
                                                                     Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" />
                                                            <Button Grid.Column="3"
                                                                    Content="Remove"
                                                                    Command="{Binding DataContext.RemoveSplitRowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Button Width="110"
                                                HorizontalAlignment="Left"
                                                Content="Add Split"
                                                Command="{Binding AddSplitRowCommand}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                                <Button Margin="0,0,8,0"
                                        Content="Create"
                                        Command="{Binding SubmitTransactionCommand}" />
                                <Button Content="Reset"
                                        Command="{Binding ResetEditorCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:EnvelopesViewModel}">
        <Grid Margin="8">
