<UserControl x:Class="DragonEnvelopes.Desktop.Controls.LoginControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Background="{StaticResource PanelBackgroundBrush}"
            CornerRadius="14"
            Padding="24"
            BorderBrush="{StaticResource PanelOutlineBrush}"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Sign In"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryTextBrush}" />
            <TextBlock Margin="0,6,0,20"
                       Text="Sign in directly from the desktop app."
                       Style="{StaticResource CaptionTextStyle}" />

            <TextBlock Text="Email or Username" />
            <TextBox x:Name="UsernameBox" Margin="0,8,0,14" />

            <TextBlock Text="Password" />
            <PasswordBox x:Name="PasswordBox" Margin="0,8,0,4" />

            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,6,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Visibility="Collapsed"
                       TextWrapping="Wrap" />

            <StackPanel Margin="0,20,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        MinWidth="92"
                        Margin="0,0,10,0"
                        Content="Cancel"
                        Click="OnCancelClicked" />
                <Button x:Name="CreateFamilyButton"
                        MinWidth="170"
                        Margin="0,0,10,0"
                        Content="Create Family Account"
                        Click="OnCreateFamilyClicked" />
                <Button x:Name="SignInButton"
                        MinWidth="110"
                        Content="Sign In"
                        Click="OnSignInClicked" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
