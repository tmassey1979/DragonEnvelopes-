                                      IsLoading="False"
                                      IsEmpty="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding EditorMessage}" Style="{StaticResource CaptionTextStyle}" />

                            <TextBlock Margin="0,12,0,6" Text="Keycloak User Id" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftKeycloakUserId, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,6" Text="Name" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,6" Text="Email" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftEmail, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,6" Text="Role" Style="{StaticResource CaptionTextStyle}" />
                            <ComboBox ItemsSource="{Binding RoleOptions}"
                                      SelectedItem="{Binding DraftRole, Mode=TwoWay}" />

                            <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                                <Button Margin="0,0,8,0"
                                        Content="Add Member"
                                        Command="{Binding AddMemberCommand}" />
                                <Button Content="Reset"
                                        Command="{Binding ResetDraftCommand}" />
                            </StackPanel>

                            <Border Margin="0,16,0,0"
                                    Padding="10"
                                    CornerRadius="8"
                                    Background="{StaticResource PanelMutedBackgroundBrush}"
                                    BorderBrush="{StaticResource PanelOutlineBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Invites" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding InviteMessage}"
                                               Style="{StaticResource CaptionTextStyle}" />

                                    <TextBlock Margin="0,12,0,6" Text="Invite Email" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftInviteEmail, UpdateSourceTrigger=PropertyChanged}" />

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Margin="0,0,0,6" Text="Role" Style="{StaticResource CaptionTextStyle}" />
                                            <ComboBox ItemsSource="{Binding RoleOptions}"
                                                      SelectedItem="{Binding DraftInviteRole, Mode=TwoWay}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Margin="0,0,0,6" Text="Expires (hours)" Style="{StaticResource CaptionTextStyle}" />
                                            <TextBox Text="{Binding DraftInviteExpiresInHours, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                        <Button Margin="0,0,8,0"
                                                Content="Create Invite"
                                                Command="{Binding CreateInviteCommand}" />
                                        <Button Content="Cancel Selected"
                                                Command="{Binding CancelInviteCommand}" />
                                    </StackPanel>

                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding LastInviteToken, StringFormat=Dev Invite Token: {0}}"
                                               Style="{StaticResource CaptionTextStyle}" />

                                    <DataGrid Margin="0,10,0,0"
                                              ItemsSource="{Binding Invites}"
                                              SelectedItem="{Binding SelectedInvite, Mode=TwoWay}"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              RowHeight="30">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="70" />
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                                            <DataGridTextColumn Header="Expires" Binding="{Binding ExpiresAtUtc}" Width="130" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:RecurringBillsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Recurring Bills" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Manage recurring bill definitions and project upcoming due dates."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Content="Reload"
                        Command="{Binding LoadCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <controls:CardControl Grid.Column="0"
                                      Header="Recurring Bills"
                                      Subheader="Create, update, and remove bill rules"
                                      EmptyMessage="No recurring bills found."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="{Binding IsEmpty}">
                    <DataGrid ItemsSource="{Binding Bills}"
                              SelectedItem="{Binding SelectedBill, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              RowHeight="34"
                              GridLinesVisibility="Horizontal"
                              Background="{StaticResource PanelMutedBackgroundBrush}"
                              BorderBrush="{StaticResource PanelOutlineBrush}"
                              BorderThickness="1"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Merchant" Binding="{Binding Merchant}" Width="160" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}" Width="100" />
                            <DataGridTextColumn Header="Frequency" Binding="{Binding Frequency}" Width="90" />
                            <DataGridTextColumn Header="Day" Binding="{Binding DayOfMonth}" Width="60" />
                            <DataGridTextColumn Header="Start" Binding="{Binding StartDate}" Width="100" />
                            <DataGridTextColumn Header="End" Binding="{Binding EndDate}" Width="100" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </controls:CardControl>

                <controls:CardControl Grid.Column="2"
                                      Header="{Binding EditorTitle}"
                                      Subheader="{Binding EditorMessage}"
                                      EmptyMessage="Recurring bill editor unavailable."
                                      IsLoading="False"
                                      IsEmpty="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Margin="0,0,0,6" Text="Name" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,6" Text="Merchant" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftMerchant, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,6" Text="Amount" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftAmount, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,6" Text="Frequency" Style="{StaticResource CaptionTextStyle}" />
                                    <ComboBox ItemsSource="{Binding FrequencyOptions}"
                                              SelectedItem="{Binding DraftFrequency, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,6" Text="Day Of Month" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftDayOfMonth, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,6" Text="Start Date (yyyy-MM-dd)" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftStartDate, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Margin="0,12,0,6" Text="End Date (optional yyyy-MM-dd)" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftEndDate, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox Margin="0,12,0,0"
                                      Content="Active"
                                      IsChecked="{Binding DraftIsActive}" />

                            <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                <Button Margin="0,0,8,0"
                                        Content="New"
                                        Command="{Binding BeginCreateCommand}" />
                                <Button Margin="0,0,8,0"
                                        Content="{Binding SaveActionLabel}"
                                        Command="{Binding SaveBillCommand}" />
                                <Button Content="Delete"
                                        Command="{Binding DeleteBillCommand}" />
                            </StackPanel>

                            <Border Margin="0,16,0,0"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="{StaticResource PanelMutedBackgroundBrush}"
                                    BorderBrush="{StaticResource PanelOutlineBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Projection Range" Style="{StaticResource CaptionTextStyle}" />

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding ProjectionFrom, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding ProjectionTo, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Button Margin="0,10,0,0"
                                            Width="130"
                                            Content="Load Projection"
                                            Command="{Binding LoadProjectionCommand}" />

                                    <DataGrid Margin="0,10,0,0"
                                              ItemsSource="{Binding ProjectionItems}"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              RowHeight="30">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate}" Width="95" />
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}" Width="95" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:ImportsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Imports" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Preview and commit transaction CSV data with dedupe awareness."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <ComboBox Grid.Column="1"
                          Margin="12,0,8,0"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                          DisplayMemberPath="Name" />

                <TextBox Grid.Column="2"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         Text="{Binding Delimiter, UpdateSourceTrigger=PropertyChanged}" />

                <Button Grid.Column="3"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Content="Preview"
                        Command="{Binding PreviewCommand}" />

                <Button Grid.Column="4"
                        VerticalAlignment="Center"
                        Content="Commit"
                        Command="{Binding CommitCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <controls:CardControl Grid.Column="0"
                                      Header="CSV Input"
                                      Subheader="Paste CSV content from your bank export"
                                      EmptyMessage="No CSV content provided."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="False">
                    <StackPanel>
                        <TextBox MinHeight="420"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Text="{Binding CsvContent, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <CheckBox Content="Include deduped rows on commit"
                                      IsChecked="{Binding IncludeDedupedRows}" />
                            <Button Margin="12,0,0,0"
                                    Content="Reset"
                                    Command="{Binding ResetCommand}" />
                        </StackPanel>
                    </StackPanel>
                </controls:CardControl>

                <controls:CardControl Grid.Column="2"
                                      Header="Preview"
                                      Subheader="{Binding PreviewSummary}"
                                      EmptyMessage="Run preview to inspect parsed rows."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="{Binding IsEmpty}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DataGrid Grid.Row="0"
                                  ItemsSource="{Binding PreviewRows}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  RowHeight="34"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource PanelMutedBackgroundBrush}"
                                  BorderBrush="{StaticResource PanelOutlineBrush}"
                                  BorderThickness="1"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="45" />
                                <DataGridTextColumn Header="Date" Binding="{Binding OccurredOn}" Width="90" />
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="90" />
                                <DataGridTextColumn Header="Merchant" Binding="{Binding Merchant}" Width="130" />
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="110" />
                                <DataGridCheckBoxColumn Header="Dup" Binding="{Binding IsDuplicate}" Width="55" />
                                <DataGridTextColumn Header="Errors" Binding="{Binding Errors}" Width="220" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="1"
                                Margin="0,10,0,0"
                                Padding="10"
                                CornerRadius="8"
                                Background="{StaticResource PanelMutedBackgroundBrush}"
                                BorderBrush="{StaticResource PanelOutlineBrush}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding CommitSummary}" Style="{StaticResource CaptionTextStyle}" />
                        </Border>
                    </Grid>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:FinancialIntegrationsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Financial Integrations" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Plaid and Stripe onboarding, card management, and controls."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Content="Reload"
                        Command="{Binding LoadCommand}" />
                <Button Grid.Column="2"
                        VerticalAlignment="Center"
                        Content="Refresh Status"
                        Command="{Binding RefreshStatusCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <ScrollViewer Grid.Row="2"
                          Margin="0,12,0,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="FinancialIntegrationsTemplateRoot">
                    <controls:CardControl Header="Status"
                                          Subheader="{Binding StatusMessage}"
                                          EmptyMessage="Status unavailable."
                                          IsLoading="{Binding IsLoading}"
                                          IsEmpty="False">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding PlaidConnected, StringFormat=Plaid Connected: {0}}" Style="{StaticResource CaptionTextStyle}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding PlaidItemIdentifierDisplay, StringFormat=Plaid Item: {0}}" Style="{StaticResource CaptionTextStyle}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding StripeConnected, StringFormat=Stripe Connected: {0}}" Style="{StaticResource CaptionTextStyle}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding StripeCustomerIdentifierDisplay, StringFormat=Stripe Customer: {0}}" Style="{StaticResource CaptionTextStyle}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding FinancialStatusUpdatedAt, StringFormat=Updated: {0}}" Style="{StaticResource CaptionTextStyle}" />
                                <Button Margin="0,8,0,0"
                                        Width="120"
                                        Content="{Binding ProviderIdentifierVisibilityLabel}"
                                        Command="{Binding ToggleProviderIdentifierVisibilityCommand}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <CheckBox Content="Email Alerts" IsChecked="{Binding NotificationEmailEnabled, Mode=TwoWay}" />
                                <CheckBox Margin="0,4,0,0" Content="In-App Alerts" IsChecked="{Binding NotificationInAppEnabled, Mode=TwoWay}" />
                                <CheckBox Margin="0,4,0,0" Content="SMS Alerts" IsChecked="{Binding NotificationSmsEnabled, Mode=TwoWay}" />
                                <Button Margin="0,8,0,0"
                                        Width="150"
                                        Content="Save Alerts"
                                        Command="{Binding SaveNotificationPreferenceCommand}" />
                            </StackPanel>
                        </Grid>
                    </controls:CardControl>

                    <controls:CardControl Margin="0,12,0,0"
                                          Header="Provider Activity and Health"
                                          Subheader="{Binding ProviderHealthStatusSummary}"
                                          EmptyMessage="Provider activity metrics unavailable."
                                          IsLoading="{Binding IsLoading}"
                                          IsEmpty="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="190" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="{Binding ProviderActivityGeneratedAt, StringFormat=Generated: {0}}" Style="{StaticResource CaptionTextStyle}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding ProviderHealthPlaidSyncAt, StringFormat=Plaid Sync: {0}}" Style="{StaticResource CaptionTextStyle}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding ProviderHealthBalanceRefreshAt, StringFormat=Balance Refresh: {0}}" Style="{StaticResource CaptionTextStyle}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding ProviderHealthDriftSummary}" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding ProviderHealthWebhookSummary}" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="{Binding ProviderHealthNotificationSummary}"
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding ProviderHealthTraceId, StringFormat=Trace Id: {0}}"
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap" />
                                <Button Margin="0,6,0,0"
                                        Width="110"
                                        Content="Copy Trace Id"
                                        Command="{Binding CopyProviderTraceIdCommand}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding ProviderHealthNotificationError}"
                                           TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Setter Property="FontSize" Value="12" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProviderHealthNotificationHasError}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Setter Property="Foreground" Value="#FFD2A8" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <WrapPanel Margin="0,10,0,0">
                                    <Button Margin="0,0,8,8"
                                            Content="Refresh Panel"
                                            Command="{Binding RefreshProviderActivityCommand}" />
                                    <Button Margin="0,0,8,8"
                                            Content="Refresh Timeline"
                                            Command="{Binding RefreshProviderTimelineCommand}" />
                                    <Button Margin="0,0,8,8"
                                            Content="Retry Plaid Sync"
                                            Command="{Binding SyncPlaidTransactionsCommand}" />
                                    <Button Margin="0,0,8,8"
                                            Content="Refresh Balances"
                                            Command="{Binding RefreshPlaidBalancesCommand}" />
                                    <Button Margin="0,0,8,8"
                                            Content="Refresh Issuance"
                                            Command="{Binding RefreshCardIssuanceCommand}" />
                                </WrapPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="3"
                                       Margin="0,10,0,6"
                                       Text="{Binding ProviderTimelineSummary}"
                                       Style="{StaticResource CaptionTextStyle}" />

                            <DataGrid Grid.Row="2"
                                      Grid.ColumnSpan="3"
                                      ItemsSource="{Binding ProviderTimelineEvents}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      RowHeight="32"
                                      GridLinesVisibility="Horizontal"
                                      Background="{StaticResource PanelMutedBackgroundBrush}"
                                      BorderBrush="{StaticResource PanelOutlineBrush}"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="130" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding EventType}" Width="170" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                                    <DataGridTextColumn Header="Occurred" Binding="{Binding OccurredAt}" Width="130" />
                                    <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*" />
                                    <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </controls:CardControl>

                    <controls:CardControl Margin="0,12,0,0"
                                          Header="Plaid"
                                          Subheader="Onboarding, account links, sync, and reconciliation"
                                          EmptyMessage="Plaid unavailable."
                                          IsLoading="{Binding IsLoading}"
                                          IsEmpty="False">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="1.4*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBox Text="{Binding PlaidClientName, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="0,8,0,0" Content="Create Link Token" Command="{Binding CreatePlaidLinkTokenCommand}" />
                                <Button Margin="0,8,0,0" Content="Launch Native Plaid Link" Command="{Binding LaunchNativePlaidLinkCommand}" />
                                <TextBox Margin="0,8,0,0" Text="{Binding PlaidLinkTokenDisplay}" IsReadOnly="True" />
                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                    <Button Margin="0,0,8,0"
                                            Width="110"
                                            Content="{Binding PlaidLinkTokenVisibilityLabel}"
                                            Command="{Binding TogglePlaidLinkTokenVisibilityCommand}" />
                                    <Button Width="92"
                                            Content="Copy Token"
                                            Command="{Binding CopyPlaidLinkTokenCommand}" />
                                </StackPanel>
                                <TextBlock Margin="0,4,0,0" Text="{Binding PlaidLinkTokenExpiresAt, StringFormat=Expires: {0}}" Style="{StaticResource CaptionTextStyle}" />
                                <TextBox Margin="0,8,0,0" Text="{Binding PlaidPublicToken, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="0,8,0,0" Content="Exchange Public Token" Command="{Binding ExchangePlaidPublicTokenCommand}" />
                                <ComboBox Margin="0,10,0,0"
                                          ItemsSource="{Binding AvailableAccounts}"
                                          SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                          DisplayMemberPath="Name" />
                                <TextBox Margin="0,8,0,0" Text="{Binding PlaidAccountId, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Margin="0,8,0,0" Content="Save Plaid Link" Command="{Binding UpsertPlaidAccountLinkCommand}" />
                                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                    <Button Margin="0,0,8,0" Content="Sync" Command="{Binding SyncPlaidTransactionsCommand}" />
                                    <Button Margin="0,0,8,0" Content="Refresh Balances" Command="{Binding RefreshPlaidBalancesCommand}" />
                                    <Button Content="Reconciliation" Command="{Binding LoadPlaidReconciliationCommand}" />
                                </StackPanel>
                                <TextBlock Margin="0,8,0,0" Text="{Binding PlaidSyncSummary}" Style="{StaticResource CaptionTextStyle}" />
                                <TextBlock Margin="0,4,0,0" Text="{Binding PlaidBalanceRefreshSummary}" Style="{StaticResource CaptionTextStyle}" />
                            </StackPanel>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="150" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="200" />
                                </Grid.RowDefinitions>

                                <DataGrid Grid.Row="0"
                                          ItemsSource="{Binding PlaidAccountLinks}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          RowHeight="32"
                                          GridLinesVisibility="Horizontal"
                                          Background="{StaticResource PanelMutedBackgroundBrush}"
                                          BorderBrush="{StaticResource PanelOutlineBrush}"
                                          BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="*" />
                                        <DataGridTextColumn Header="Plaid Id" Binding="{Binding PlaidAccountId}" Width="180" />
                                        <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedAt}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Grid.Row="1"
                                           Margin="0,8,0,8"
                                           Text="{Binding PlaidReconciliationGeneratedAt, StringFormat=Generated: {0}}"
                                           Style="{StaticResource CaptionTextStyle}" />
                                <DataGrid Grid.Row="2"
                                          ItemsSource="{Binding PlaidReconciliationAccounts}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          RowHeight="32"
                                          GridLinesVisibility="Horizontal"
                                          Background="{StaticResource PanelMutedBackgroundBrush}"
                                          BorderBrush="{StaticResource PanelOutlineBrush}"
                                          BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="*" />
                                        <DataGridTextColumn Header="Internal" Binding="{Binding InternalBalance}" Width="100" />
                                        <DataGridTextColumn Header="Provider" Binding="{Binding ProviderBalance}" Width="100" />
                                        <DataGridTextColumn Header="Drift" Binding="{Binding DriftAmount}" Width="100" />
                                        <DataGridCheckBoxColumn Header="Flag" Binding="{Binding IsDrifted}" Width="55" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </controls:CardControl>

                    <controls:CardControl Margin="0,12,0,0"
                                          Header="Stripe and Card Management"
                                          Subheader="{Binding SelectedEnvelopeSummary}"
                                          EmptyMessage="Card management unavailable."
                                          IsLoading="{Binding IsLoading}"
                                          IsEmpty="False">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" Text="{Binding StripeSetupEmail, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="2" Text="{Binding StripeSetupName, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="4"
                                        Content="Create Setup Intent"
                                        Command="{Binding CreateStripeSetupIntentCommand}" />
                            </Grid>

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding StripeSetupIntentIdDisplay, StringFormat=Setup Intent: {0}}"
                                       Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding StripeSetupCustomerIdDisplay, StringFormat=Stripe Customer: {0}}"
                                       Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Margin="0,6,0,0" Text="{Binding StripeClientSecretDisplay}" IsReadOnly="True" />
                            <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                <Button Margin="0,0,8,0"
                                        Width="110"
                                        Content="{Binding StripeClientSecretVisibilityLabel}"
                                        Command="{Binding ToggleStripeClientSecretVisibilityCommand}" />
                                <Button Width="100"
                                        Content="Copy Secret"
                                        Command="{Binding CopyStripeClientSecretCommand}" />
                            </StackPanel>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding AvailableEnvelopes}"
                                          SelectedItem="{Binding SelectedEnvelope, Mode=TwoWay}"
                                          DisplayMemberPath="Name" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding StripeFinancialAccountDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="4"
                                        Content="Link Account"
                                        Command="{Binding LinkStripeFinancialAccountCommand}" />
                            </Grid>

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding EnvelopeFinancialAccountSummary}"
                                       Style="{StaticResource CaptionTextStyle}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBox Text="{Binding VirtualCardholderName, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Margin="0,8,0,0" Content="Issue Virtual Card" Command="{Binding IssueVirtualCardCommand}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBox Text="{Binding PhysicalCardholderName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding ShipmentRecipientName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding ShipmentAddressLine1, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding ShipmentCity, UpdateSourceTrigger=PropertyChanged}" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding ShipmentStateOrProvince, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="2" Text="{Binding ShipmentPostalCode, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="4" Text="{Binding ShipmentCountryCode, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Button Margin="0,8,0,0" Content="Issue Physical Card" Command="{Binding IssuePhysicalCardCommand}" />
                                </StackPanel>
                            </Grid>

                            <DataGrid Margin="0,10,0,0"
                                      Height="170"
                                      ItemsSource="{Binding Cards}"
                                      SelectedItem="{Binding SelectedCard, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      RowHeight="32"
                                      GridLinesVisibility="Horizontal"
                                      Background="{StaticResource PanelMutedBackgroundBrush}"
                                      BorderBrush="{StaticResource PanelOutlineBrush}"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                                    <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="90" />
                                    <DataGridTextColumn Header="Last4" Binding="{Binding Last4}" Width="70" />
                                    <DataGridTextColumn Header="Provider Card Id" Binding="{Binding ProviderCardId}" Width="220" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                <Button Margin="0,0,8,0" Content="Freeze" Command="{Binding FreezeSelectedCardCommand}" />
                                <Button Margin="0,0,8,0" Content="Unfreeze" Command="{Binding UnfreezeSelectedCardCommand}" />
                                <Button Margin="0,0,8,0" Content="Cancel" Command="{Binding CancelSelectedCardCommand}" />
                                <Button Content="Refresh Issuance" Command="{Binding RefreshCardIssuanceCommand}" />
                            </StackPanel>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding IssuanceSummary}"
                                       Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>
                    </controls:CardControl>

                    <controls:CardControl Margin="0,12,0,0"
                                          Header="Card Controls and Evaluation"
                                          Subheader="{Binding CardControlSummary}"
                                          EmptyMessage="Select a card to manage controls."
                                          IsLoading="{Binding IsLoading}"
                                          IsEmpty="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="170" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBox Text="{Binding CardControlDailyLimit, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding CardControlAllowedCategories, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding CardControlAllowedMerchants, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Margin="0,8,0,0" Content="Save Controls" Command="{Binding SaveCardControlsCommand}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBox Text="{Binding CardSpendMerchantName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding CardSpendMerchantCategory, UpdateSourceTrigger=PropertyChanged}" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding CardSpendAmount, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="2" Text="{Binding CardSpendTodayAmount, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Button Margin="0,8,0,0" Content="Evaluate Spend" Command="{Binding EvaluateCardSpendCommand}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding CardSpendEvaluationResult}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource CaptionTextStyle}" />
                                </StackPanel>
                            </Grid>

                            <DataGrid Grid.Row="1"
                                      Margin="0,10,0,0"
                                      ItemsSource="{Binding CardControlAuditEntries}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      RowHeight="32"
                                      GridLinesVisibility="Horizontal"
                                      Background="{StaticResource PanelMutedBackgroundBrush}"
                                      BorderBrush="{StaticResource PanelOutlineBrush}"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="120" />
                                    <DataGridTextColumn Header="Changed By" Binding="{Binding ChangedBy}" Width="170" />
                                    <DataGridTextColumn Header="Changed At" Binding="{Binding ChangedAt}" Width="130" />
                                    <DataGridTextColumn Header="Previous" Binding="{Binding PreviousStateJson}" Width="*" />
                                    <DataGridTextColumn Header="New" Binding="{Binding NewStateJson}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </controls:CardControl>

                    <controls:CardControl Margin="0,12,0,0"
                                          Header="Security Event Log"
                                          Subheader="Reveal/copy actions for sensitive values are recorded locally"
                                          EmptyMessage="No security events yet."
                                          IsLoading="{Binding IsLoading}"
                                          IsEmpty="False">
                        <DataGrid ItemsSource="{Binding SecurityAuditEvents}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  RowHeight="32"
                                  GridLinesVisibility="Horizontal"
                                  Background="{StaticResource PanelMutedBackgroundBrush}"
                                  BorderBrush="{StaticResource PanelOutlineBrush}"
                                  BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="160" />
                                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </controls:CardControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Settings" Style="{StaticResource DisplayTextStyle}" />
                <TextBlock Margin="0,8,0,0"
                           Text="Session controls, profile placeholders, and runtime metadata."
                           Style="{StaticResource BodyTextStyle}" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:CardControl Grid.Row="0"
                                      Header="Session Controls"
                                      Subheader="Manage local desktop authentication state"
                                      EmptyMessage="Session controls unavailable."
                                      IsLoading="False"
                                      IsEmpty="False">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="{Binding SessionStatus}"
                                   Style="{StaticResource BodyTextStyle}" />
                        <Button Grid.Column="1"
                                Margin="12,0,8,0"
                                Content="Refresh Status"
                                Command="{Binding ReloadStatusCommand}" />
                        <Button Grid.Column="2"
                                Content="Sign Out"
                                Command="{Binding SignOutCommand}" />
                    </Grid>
                </controls:CardControl>

                <controls:CardControl Grid.Row="1"
                                      Margin="0,12,0,0"
                                      Header="Profile Preferences"
                                      Subheader="Placeholder controls for upcoming profile settings"
                                      EmptyMessage="{Binding ProfilePlaceholderMessage}"
                                      IsLoading="False"
                                      IsEmpty="False">
                    <StackPanel>
                        <TextBlock Text="{Binding ProfilePlaceholderMessage}" Style="{StaticResource CaptionTextStyle}" />
                        <TextBox Margin="0,8,0,0" Text="Display name (coming soon)" IsReadOnly="True" />
                        <TextBox Margin="0,8,0,0" Text="Default family (coming soon)" IsReadOnly="True" />
                    </StackPanel>
                </controls:CardControl>

                <controls:CardControl Grid.Row="2"
                                      Margin="0,12,0,0"
                                      Header="Application Metadata"
                                      Subheader="Current runtime configuration"
                                      EmptyMessage="Metadata unavailable."
                                      IsLoading="False"
                                      IsEmpty="False">
                    <StackPanel>
                        <TextBlock Text="{Binding EnvironmentName, StringFormat=Environment: {0}}" Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding AppVersion, StringFormat=Desktop Version: {0}}"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding BackendHealthStatus, StringFormat=Backend Health: {0}}"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding BackendVersion, StringFormat=Backend Version: {0}}"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding BackendEnvironment, StringFormat=Backend Environment: {0}}"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding BackendCheckedAt, StringFormat=Backend Checked: {0}}"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding BackendStatusMessage}"
                                   Style="{StaticResource CaptionTextStyle}" />
                    </StackPanel>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:OnboardingWizardViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Onboarding Wizard" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Guided setup for accounts, envelopes, and initial budget configuration."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Content="Reload"
                        Command="{Binding LoadCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:CardControl Grid.Column="0"
                                      Header="Steps"
                                      Subheader="{Binding StatusMessage}"
                                      EmptyMessage="No steps available."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="False">
                    <StackPanel>
                        <TextBlock Text="{Binding ProgressPercent, StringFormat=Progress: {0}%}"
                                   Style="{StaticResource CaptionTextStyle}" />

                        <ItemsControl Margin="0,10,0,0"
                                      ItemsSource="{Binding Steps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="8"
                                            CornerRadius="8"
                                            Background="{StaticResource PanelMutedBackgroundBrush}"
                                            BorderBrush="{StaticResource PanelOutlineBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding}" Style="{StaticResource CaptionTextStyle}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </controls:CardControl>

                <controls:CardControl Grid.Column="2"
                                      Header="{Binding CurrentStepTitle}"
                                      Subheader="Wizard shell"
                                      EmptyMessage="Step content unavailable."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="False">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource BodyTextStyle}" />

                        <Border Margin="0,12,0,0"
                                Padding="10"
                                CornerRadius="8"
                                Background="{StaticResource PanelMutedBackgroundBrush}"
                                BorderBrush="{StaticResource PanelOutlineBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Accounts" Style="{StaticResource CaptionTextStyle}" />
                                <ItemsControl Margin="0,8,0,0"
                                              ItemsSource="{Binding AccountDrafts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                <ComboBox Grid.Column="2"
                                                          ItemsSource="{Binding DataContext.AccountTypeOptions, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                                          SelectedItem="{Binding Type, Mode=TwoWay}" />
                                                <TextBox Grid.Column="4"
                                                         Text="{Binding OpeningBalance, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Grid.Column="6"
                                                        Content="Remove"
                                                        Command="{Binding DataContext.RemoveAccountRowCommand, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Width="120"
                                        Content="Add Account"
                                        Command="{Binding AddAccountRowCommand}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Padding="10"
                                CornerRadius="8"
                                Background="{StaticResource PanelMutedBackgroundBrush}"
                                BorderBrush="{StaticResource PanelOutlineBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Envelopes" Style="{StaticResource CaptionTextStyle}" />
                                <ItemsControl Margin="0,8,0,0"
                                              ItemsSource="{Binding EnvelopeDrafts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.8*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Column="2"
                                                         Text="{Binding MonthlyBudget, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Grid.Column="4"
                                                        Content="Remove"
                                                        Command="{Binding DataContext.RemoveEnvelopeRowCommand, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Width="130"
                                        Content="Add Envelope"
                                        Command="{Binding AddEnvelopeRowCommand}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Padding="10"
                                CornerRadius="8"
                                Background="{StaticResource PanelMutedBackgroundBrush}"
                                BorderBrush="{StaticResource PanelOutlineBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Starter Budget (optional)" Style="{StaticResource CaptionTextStyle}" />
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding BudgetMonth, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Column="2"
                                             Text="{Binding BudgetIncome, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,18,0,0"
                                    Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Content="Back"
                                    IsEnabled="{Binding CanGoBack}"
                                    Command="{Binding PreviousStepCommand}" />
                            <Button Margin="0,0,8,0"
                                    Content="Mark Complete"
                                    Command="{Binding MarkCurrentStepCompleteCommand}" />
                            <Button Margin="0,0,8,0"
                                    Content="Next"
                                    IsEnabled="{Binding CanGoNext}"
                                    Command="{Binding NextStepCommand}" />
                            <Button Margin="0,0,8,0"
                                    Content="Submit Setup"
                                    Command="{Binding SubmitBootstrapCommand}" />
                            <Button Content="Cancel"
                                    Command="{Binding CancelCommand}" />
                        </StackPanel>
                    </StackPanel>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
