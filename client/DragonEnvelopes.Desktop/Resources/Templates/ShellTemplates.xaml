                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Merchant" Binding="{Binding Merchant}" Width="160" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}" Width="100" />
                            <DataGridTextColumn Header="Frequency" Binding="{Binding Frequency}" Width="90" />
                            <DataGridTextColumn Header="Day" Binding="{Binding DayOfMonth}" Width="60" />
                            <DataGridTextColumn Header="Start" Binding="{Binding StartDate}" Width="100" />
                            <DataGridTextColumn Header="End" Binding="{Binding EndDate}" Width="100" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </controls:CardControl>

                <controls:CardControl Grid.Column="2"
                                      Header="{Binding EditorTitle}"
                                      Subheader="{Binding EditorMessage}"
                                      EmptyMessage="Recurring bill editor unavailable."
                                      IsLoading="False"
                                      IsEmpty="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Margin="0,0,0,6" Text="Name" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,6" Text="Merchant" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftMerchant, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,6" Text="Amount" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftAmount, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,6" Text="Frequency" Style="{StaticResource CaptionTextStyle}" />
                                    <ComboBox ItemsSource="{Binding FrequencyOptions}"
                                              SelectedItem="{Binding DraftFrequency, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,6" Text="Day Of Month" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftDayOfMonth, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,6" Text="Start Date (yyyy-MM-dd)" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftStartDate, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Margin="0,12,0,6" Text="End Date (optional yyyy-MM-dd)" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftEndDate, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox Margin="0,12,0,0"
                                      Content="Active"
                                      IsChecked="{Binding DraftIsActive}" />

                            <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                <Button Margin="0,0,8,0"
                                        Content="New"
                                        Command="{Binding BeginCreateCommand}" />
                                <Button Margin="0,0,8,0"
                                        Content="{Binding SaveActionLabel}"
                                        Command="{Binding SaveBillCommand}" />
                                <Button Content="Delete"
                                        Command="{Binding DeleteBillCommand}" />
                            </StackPanel>

                            <Border Margin="0,16,0,0"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="{StaticResource PanelMutedBackgroundBrush}"
                                    BorderBrush="{StaticResource PanelOutlineBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Projection Range" Style="{StaticResource CaptionTextStyle}" />

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding ProjectionFrom, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding ProjectionTo, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Button Margin="0,10,0,0"
                                            Width="130"
                                            Content="Load Projection"
                                            Command="{Binding LoadProjectionCommand}" />

                                    <DataGrid Margin="0,10,0,0"
                                              ItemsSource="{Binding ProjectionItems}"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              RowHeight="30">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate}" Width="95" />
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}" Width="95" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Settings" Style="{StaticResource DisplayTextStyle}" />
                <TextBlock Margin="0,8,0,0"
                           Text="Session controls, profile placeholders, and runtime metadata."
                           Style="{StaticResource BodyTextStyle}" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:CardControl Grid.Row="0"
                                      Header="Session Controls"
                                      Subheader="Manage local desktop authentication state"
                                      EmptyMessage="Session controls unavailable."
                                      IsLoading="False"
                                      IsEmpty="False">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="{Binding SessionStatus}"
                                   Style="{StaticResource BodyTextStyle}" />
                        <Button Grid.Column="1"
                                Margin="12,0,8,0"
                                Content="Refresh Session"
                                Command="{Binding ReloadSessionCommand}" />
                        <Button Grid.Column="2"
                                Content="Sign Out"
                                Command="{Binding SignOutCommand}" />
                    </Grid>
                </controls:CardControl>

                <controls:CardControl Grid.Row="1"
                                      Margin="0,12,0,0"
                                      Header="Profile Preferences"
                                      Subheader="Placeholder controls for upcoming profile settings"
                                      EmptyMessage="{Binding ProfilePlaceholderMessage}"
                                      IsLoading="False"
                                      IsEmpty="False">
                    <StackPanel>
                        <TextBlock Text="{Binding ProfilePlaceholderMessage}" Style="{StaticResource CaptionTextStyle}" />
                        <TextBox Margin="0,8,0,0" Text="Display name (coming soon)" IsReadOnly="True" />
                        <TextBox Margin="0,8,0,0" Text="Default family (coming soon)" IsReadOnly="True" />
                    </StackPanel>
                </controls:CardControl>

                <controls:CardControl Grid.Row="2"
                                      Margin="0,12,0,0"
                                      Header="Application Metadata"
                                      Subheader="Current runtime configuration"
                                      EmptyMessage="Metadata unavailable."
                                      IsLoading="False"
                                      IsEmpty="False">
                    <StackPanel>
                        <TextBlock Text="{Binding EnvironmentName, StringFormat=Environment: {0}}" Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding AppVersion, StringFormat=Desktop Version: {0}}"
                                   Style="{StaticResource CaptionTextStyle}" />
                    </StackPanel>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
