<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:viewModels="clr-namespace:DragonEnvelopes.Desktop.ViewModels">
    <DataTemplate DataType="{x:Type viewModels:ShellContentViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="{Binding Title}" Style="{StaticResource DisplayTextStyle}" />
                <TextBlock Margin="0,8,0,0"
                           Text="{Binding Description}"
                           Style="{StaticResource BodyTextStyle}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    CornerRadius="18"
                    Padding="24"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource PanelOutlineBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding EmptyStateTitle}" Style="{StaticResource HeadingTextStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding EmptyStateBody}"
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
