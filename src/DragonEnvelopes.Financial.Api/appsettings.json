{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=dragonenvelopes_family;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "Authority": "http://localhost:18080/realms/dragonenvelopes",
    "PublicAuthority": "http://localhost:18080/realms/dragonenvelopes",
    "Audience": "dragonenvelopes-api",
    "AllowedAuthorizedParties": [
      "dragonenvelopes-api",
      "dragonenvelopes-desktop"
    ]
  },
  "Keycloak": {
    "ServerUrl": "http://localhost:18080",
    "Realm": "dragonenvelopes",
    "AdminRealm": "master",
    "AdminClientId": "admin-cli",
    "AdminUsername": "admin",
    "AdminPassword": "admin"
  },
  "FamilyInvites": {
    "Email": {
      "Enabled": false,
      "UseSmtp": false,
      "InviteBaseUrl": "http://localhost:5173",
      "FromAddress": "noreply@dragonenvelopes.local",
      "SmtpHost": "",
      "SmtpPort": 25,
      "SmtpUsername": "",
      "SmtpPassword": "",
      "SmtpEnableSsl": false
    }
  },
  "Observability": {
    "EnableLokiSink": false,
    "LokiUrl": "http://localhost:3100"
  },
  "Messaging": {
    "RabbitMq": {
      "Enabled": false,
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "guest",
      "Password": "guest",
      "VirtualHost": "/",
      "ExchangeName": "dragonenvelopes.events",
      "ExchangeType": "topic",
      "DurableExchange": true,
      "SourceService": "financial-api",
      "EnableLedgerTransactionConsumer": true,
      "LedgerTransactionCreatedQueue": "dragonenvelopes.financial.ledger-transaction-created",
      "LedgerTransactionCreatedRetryQueue": "dragonenvelopes.financial.ledger-transaction-created.retry",
      "LedgerTransactionCreatedRetryRoutingKey": "ledger.transaction.created.retry.v1",
      "LedgerTransactionCreatedDeadLetterQueue": "dragonenvelopes.financial.ledger-transaction-created.dlq",
      "LedgerTransactionCreatedDeadLetterRoutingKey": "ledger.transaction.created.dlq.v1",
      "ConsumerMaxRetryAttempts": 5,
      "ConsumerRetryDelayMilliseconds": 30000,
      "ConsumerPrefetchCount": 20
    },
    "Outbox": {
      "Enabled": true,
      "PollIntervalSeconds": 5,
      "BatchSize": 50,
      "BacklogWarningThreshold": 100
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Grafana.Loki"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "DragonEnvelopes.Financial.Api"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

