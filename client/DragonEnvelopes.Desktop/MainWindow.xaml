<Window x:Class="DragonEnvelopes.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:DragonEnvelopes.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="DragonEnvelopes"
        Width="1280"
        Height="800"
        MinWidth="1024"
        MinHeight="640"
        Background="{StaticResource ShellBackgroundBrush}">
    <Window.DataContext>
        <viewModels:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="74" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource PanelOutlineBrush}"
                BorderThickness="0,0,1,0"
                Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="DragonEnvelopes"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="26"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Family Budget Workspace"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="12" />
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              Margin="0,32,0,0"
                              ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,0,10"
                                    Padding="14,12"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="10"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#202D4A" />
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#2A3A61" />
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                                                <Setter Property="BorderBrush" Value="#4B669E" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Glyph}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="15"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Margin="8,0,0,0"
                                               Text="{Binding Label}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="2"
                        Padding="12"
                        CornerRadius="10"
                        Background="#1F2A45"
                        BorderBrush="#30466E"
                        BorderThickness="1">
                    <TextBlock Text="Sidebar and topbar stay fixed while main content swaps by binding."
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Background="#101728"
                BorderBrush="{StaticResource PanelOutlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TopBarTitle}"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding TopBarSubtitle}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="12" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,8"
                        CornerRadius="8"
                        Background="#1B2947"
                        BorderBrush="#335281"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="v1 Shell"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="24">
            <ContentControl Content="{Binding CurrentContent}" />
        </Border>
    </Grid>
</Window>
