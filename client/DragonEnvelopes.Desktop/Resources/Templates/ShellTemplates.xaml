                            <Button Margin="0,0,8,0"
                                    Content="Archive"
                                    Command="{Binding ArchiveCommand}" />
                            <Button Content="Cancel"
                                    Command="{Binding CancelEditCommand}" />
                        </StackPanel>
                    </StackPanel>
