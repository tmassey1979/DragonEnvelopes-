<UserControl x:Class="DragonEnvelopes.Desktop.Controls.TransactionRowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Padding="10"
            Margin="0,0,0,8"
            CornerRadius="10"
            Background="{StaticResource PanelMutedBackgroundBrush}"
            BorderBrush="{StaticResource PanelOutlineBrush}"
            BorderThickness="1"
            Focusable="True">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected, ElementName=Root}" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        <Setter Property="BorderThickness" Value="2" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsFlagged, ElementName=Root}" Value="True">
                        <Setter Property="BorderBrush" Value="#FF9F9F" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsEdited, ElementName=Root}" Value="True">
                        <Setter Property="Background" Value="#2A3D5F" />
                    </DataTrigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#293D62" />
                    </Trigger>
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        <Setter Property="BorderThickness" Value="2" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="85" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding Date, ElementName=Root}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="{Binding Merchant, ElementName=Root}" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="{Binding Amount, ElementName=Root}" Style="{StaticResource BodyTextStyle}" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" />
            <TextBlock Grid.Column="3" Text="{Binding Envelope, ElementName=Root}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="4" Text="{Binding Category, ElementName=Root}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />

            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Margin="0,0,6,0"
                        Padding="10,4"
                        FontSize="12"
                        Content="Edit"
                        Command="{Binding EditCommand, ElementName=Root}"
                        CommandParameter="{Binding CommandParameter, ElementName=Root}" />
                <Button Padding="10,4"
                        FontSize="12"
                        Content="Split"
                        Command="{Binding SplitCommand, ElementName=Root}"
                        CommandParameter="{Binding CommandParameter, ElementName=Root}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
