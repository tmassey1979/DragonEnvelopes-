<Window x:Class="DragonEnvelopes.Desktop.Views.CreateFamilyAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Create Family Account"
        Width="520"
        Height="600"
        MinWidth="460"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource ShellBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="22">
        <Border Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="14"
                Padding="22"
                BorderBrush="{StaticResource PanelOutlineBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Create Family Account"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Margin="0,6,0,16"
                               Style="{StaticResource CaptionTextStyle}"
                               Text="Set up your household workspace in DragonEnvelopes." />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Family Name" />
                    <TextBox x:Name="FamilyNameBox" Margin="0,8,0,12" />

                    <TextBlock Text="Primary Guardian Name" />
                    <TextBox x:Name="GuardianNameBox" Margin="0,8,0,12" />

                    <TextBlock Text="Email" />
                    <TextBox x:Name="EmailBox" Margin="0,8,0,12" />

                    <TextBlock Text="Password" />
                    <PasswordBox x:Name="PasswordBox" Margin="0,8,0,12" />

                    <TextBlock Text="Confirm Password" />
                    <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,8,0,0" />

                    <TextBlock x:Name="ValidationText"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource AccentBrush}"
                               Visibility="Collapsed"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="0,16,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button MinWidth="88"
                            Margin="0,0,10,0"
                            Content="Cancel"
                            Click="OnCancelClicked" />
                    <Button x:Name="CreateButton"
                            MinWidth="124"
                            Content="Create Account"
                            Click="OnCreateClicked" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
