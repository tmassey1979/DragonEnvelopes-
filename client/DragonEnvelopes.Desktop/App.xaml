<Application x:Class="DragonEnvelopes.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/Colors.Dark.xaml" />
                <ResourceDictionary Source="Resources/Themes/Typography.xaml" />
                <ResourceDictionary Source="Resources/Themes/Controls.xaml" />
                <ResourceDictionary Source="Resources/Templates/ShellTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
