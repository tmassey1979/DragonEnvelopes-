                                      Header="Rules"
                                      Subheader="Priority order (first-match wins)"
                                      EmptyMessage="No automation rules found for current filters."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="{Binding IsEmpty}">
                    <DataGrid ItemsSource="{Binding Rules}"
                              SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              RowHeight="34"
                              GridLinesVisibility="Horizontal"
                              Background="{StaticResource PanelMutedBackgroundBrush}"
                              BorderBrush="{StaticResource PanelOutlineBrush}"
                              BorderThickness="1"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Type" Binding="{Binding RuleType}" Width="120" />
                            <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="80" />
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="80" />
                            <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedAtDisplay}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </controls:CardControl>

                <controls:CardControl Grid.Column="2"
                                      Header="{Binding EditorTitle}"
                                      Subheader="{Binding EditorStatus}"
                                      EmptyMessage="Rule editor unavailable."
                                      IsLoading="False"
                                      IsEmpty="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Margin="0,0,0,6" Text="Name" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox Text="{Binding DraftName, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,6" Text="Rule Type" Style="{StaticResource CaptionTextStyle}" />
                                    <ComboBox ItemsSource="{Binding RuleTypeOptions}"
                                              SelectedItem="{Binding DraftRuleType}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,6" Text="Priority" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBox Text="{Binding DraftPriority, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <CheckBox Margin="0,14,0,0"
                                      Content="Enabled"
                                      IsChecked="{Binding DraftIsEnabled}" />

                            <TextBlock Margin="0,14,0,6" Text="Conditions JSON" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox MinHeight="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding DraftConditionsJson, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,14,0,6" Text="Action JSON" Style="{StaticResource CaptionTextStyle}" />
                            <TextBox MinHeight="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding DraftActionJson, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                                <Button Margin="0,0,8,0"
                                        Content="New"
                                        Command="{Binding BeginCreateCommand}" />
                                <Button Margin="0,0,8,0"
                                        Content="Save"
                                        Command="{Binding SaveCommand}" />
                                <Button Margin="0,0,8,0"
                                        Content="Enable/Disable"
                                        Command="{Binding ToggleEnabledCommand}" />
                                <Button Content="Delete"
                                        Command="{Binding DeleteCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>

