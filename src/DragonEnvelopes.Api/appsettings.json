{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=dragonenvelopes_app;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "Authority": "http://localhost:18080/realms/dragonenvelopes",
    "PublicAuthority": "http://localhost:18080/realms/dragonenvelopes",
    "Audience": "dragonenvelopes-api",
    "AllowedAuthorizedParties": [
      "dragonenvelopes-api",
      "dragonenvelopes-desktop"
    ]
  },
  "Keycloak": {
    "ServerUrl": "http://localhost:18080",
    "Realm": "dragonenvelopes",
    "AdminRealm": "master",
    "AdminClientId": "admin-cli",
    "AdminUsername": "admin",
    "AdminPassword": "admin"
  },
  "Observability": {
    "EnableLokiSink": false,
    "LokiUrl": "http://localhost:3100"
  },
  "FamilyInvites": {
    "Email": {
      "Enabled": false,
      "UseSmtp": false,
      "InviteBaseUrl": "http://localhost:5173",
      "FromAddress": "noreply@dragonenvelopes.local",
      "SmtpHost": "",
      "SmtpPort": 25,
      "SmtpUsername": "",
      "SmtpPassword": "",
      "SmtpEnableSsl": false
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Grafana.Loki"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "DragonEnvelopes.Api"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
