<Window x:Class="DragonEnvelopes.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DragonEnvelopes.Desktop.Controls"
        xmlns:viewModels="clr-namespace:DragonEnvelopes.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="DragonEnvelopes"
        Width="1280"
        Height="800"
        MinWidth="1024"
        MinHeight="640"
        Background="{StaticResource ShellBackgroundBrush}">
    <Window.DataContext>
        <viewModels:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="74" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource PanelOutlineBrush}"
                BorderThickness="0,0,1,0"
                Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="DragonEnvelopes" Style="{StaticResource HeadingTextStyle}" FontSize="26" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Family Budget Workspace"
                               Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              Margin="0,32,0,0"
                              ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:SidebarItemControl Glyph="{Binding Glyph}"
                                                         Label="{Binding Label}"
                                                         IsSelected="{Binding IsSelected}"
                                                         Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="2"
                        Padding="12"
                        CornerRadius="10"
                        Background="{StaticResource PanelMutedBackgroundBrush}"
                        BorderBrush="{StaticResource PanelOutlineBrush}"
                        BorderThickness="1">
                    <TextBlock Text="Sidebar and topbar stay fixed while main content swaps by binding."
                               Style="{StaticResource CaptionTextStyle}" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Background="{StaticResource ShellBackgroundBrush}"
                BorderBrush="{StaticResource PanelOutlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TopBarTitle}" Style="{StaticResource HeadingTextStyle}" FontSize="24" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding TopBarSubtitle}"
                               Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>

                <TextBox Grid.Column="1"
                         Margin="16,0,12,0"
                         VerticalAlignment="Center"
                         Text="Search routes..."
                         IsReadOnly="True" />

                <TextBlock Grid.Column="2"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center"
                           Text="{Binding AuthStatus}"
                           Style="{StaticResource CaptionTextStyle}" />

                <TextBlock Grid.Column="3"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center"
                           Text="{Binding ApiStatus}"
                           Style="{StaticResource CaptionTextStyle}" />

                <Border Grid.Column="4"
                        Padding="12,8"
                        CornerRadius="8"
                        Background="{StaticResource AccentMutedBrush}"
                        BorderBrush="{StaticResource PanelOutlineBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="Dark Theme" Style="{StaticResource CaptionTextStyle}" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                </Border>

                <Button Grid.Column="5"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        MinWidth="92"
                        Content="{Binding AuthActionLabel}"
                        Command="{Binding ToggleAuthenticationCommand}" />

                <Button Grid.Column="6"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        MinWidth="84"
                        Content="Ping API"
                        Command="{Binding PingApiCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="24">
            <ContentControl Content="{Binding CurrentContent}" />
        </Border>
    </Grid>
</Window>
