<UserControl x:Class="DragonEnvelopes.Desktop.Controls.LoginControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Background="{StaticResource PanelBackgroundBrush}"
            CornerRadius="14"
            Padding="24"
            BorderBrush="{StaticResource PanelOutlineBrush}"
            BorderThickness="1">
        <StackPanel KeyboardNavigation.TabNavigation="Cycle">
            <StackPanel x:Name="WelcomePanel">
                <TextBlock Text="Welcome to DragonEnvelopes"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Margin="0,6,0,20"
                           Text="Choose an entry path to start onboarding or sign in."
                           Style="{StaticResource CaptionTextStyle}" />

                <StackPanel Margin="0,8,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="CancelWelcomeButton"
                            MinWidth="92"
                            Margin="0,0,10,0"
                            Content="Cancel"
                            IsCancel="True"
                            AutomationProperties.Name="Cancel welcome"
                            Click="OnCancelClicked" />
                    <Button x:Name="GetStartedButton"
                            MinWidth="140"
                            Margin="0,0,10,0"
                            Content="Get Started"
                            AutomationProperties.Name="Get started"
                            Click="OnGetStartedClicked" />
                    <Button x:Name="RouteToSignInButton"
                            MinWidth="110"
                            Content="Sign In"
                            AutomationProperties.Name="Route to sign in"
                            Click="OnRouteToSignInClicked" />
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="SignInPanel"
                        Visibility="Collapsed">
                <TextBlock Text="Sign In"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Margin="0,6,0,20"
                           Text="Sign in directly from the desktop app."
                           Style="{StaticResource CaptionTextStyle}" />

                <Label Content="_Email or Username"
                       Target="{Binding ElementName=UsernameBox}" />
                <TextBox x:Name="UsernameBox"
                         Margin="0,8,0,14"
                         AutomationProperties.Name="Email or Username" />

                <Label Content="_Password"
                       Target="{Binding ElementName=PasswordBox}" />
                <PasswordBox x:Name="PasswordBox"
                             Margin="0,8,0,4"
                             AutomationProperties.Name="Password" />

                <TextBlock x:Name="StatusTextBlock"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"
                           AutomationProperties.LiveSetting="Polite" />

                <StackPanel Margin="0,20,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="BackButton"
                            MinWidth="92"
                            Margin="0,0,10,0"
                            Content="Back"
                            AutomationProperties.Name="Back to welcome"
                            Click="OnBackClicked" />
                    <Button x:Name="CreateFamilyButton"
                            MinWidth="130"
                            Margin="0,0,10,0"
                            Content="Create Family"
                            AutomationProperties.Name="Create family account"
                            Click="OnCreateFamilyClicked" />
                    <Button x:Name="CancelButton"
                            MinWidth="92"
                            Margin="0,0,10,0"
                            Content="Cancel"
                            IsCancel="True"
                            AutomationProperties.Name="Cancel sign in"
                            Click="OnCancelClicked" />
                    <Button x:Name="RedeemInviteButton"
                            MinWidth="130"
                            Margin="0,0,10,0"
                            Content="Redeem Invite"
                            AutomationProperties.Name="Redeem invite token"
                            Click="OnRedeemInviteClicked" />
                    <Button x:Name="CreateInviteAccountButton"
                            MinWidth="170"
                            Margin="0,0,10,0"
                            Content="Create From Invite"
                            AutomationProperties.Name="Create account from invite token"
                            Click="OnCreateInviteAccountClicked" />
                    <Button x:Name="SignInButton"
                            MinWidth="110"
                            Content="Sign In"
                            IsDefault="True"
                            AutomationProperties.Name="Sign in"
                            Click="OnSignInClicked" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
