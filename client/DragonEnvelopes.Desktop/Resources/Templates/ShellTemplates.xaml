<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:DragonEnvelopes.Desktop.Controls"
                    xmlns:viewModels="clr-namespace:DragonEnvelopes.Desktop.ViewModels">
    <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dashboard" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Net worth, balances, and recent activity health at a glance."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Content="Reload"
                        Command="{Binding LoadCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <controls:CardControl Grid.Row="0"
                                      Header="Budget KPI Cards"
                                      Subheader="Current financial health snapshot"
                                      EmptyMessage="No KPI data returned."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="{Binding IsEmpty}">
                    <ItemsControl ItemsSource="{Binding KpiCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel ItemWidth="220" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:MetricTileViewModel}">
                                <controls:MetricTileControl Margin="0,0,14,14"
                                                            Label="{Binding Label}"
                                                            Value="{Binding Value}"
                                                            Trend="{Binding Trend}"
                                                            TrendDirection="{Binding TrendDirection}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:CardControl>

                <controls:CardControl Grid.Row="1"
                                      Margin="0,14,0,0"
                                      Header="Recent Transactions"
                                      Subheader="Most recent posted activity"
                                      EmptyMessage="No recent transactions found."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="{Binding IsEmpty}">
                    <ItemsControl ItemsSource="{Binding RecentTransactions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:TransactionRowViewModel}">
                                <controls:TransactionRowControl Date="{Binding Date}"
                                                                Merchant="{Binding Merchant}"
                                                                Amount="{Binding Amount}"
                                                                Envelope="{Binding Envelope}"
                                                                Category="{Binding Category}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:ShellContentViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="{Binding Title}" Style="{StaticResource DisplayTextStyle}" />
                <TextBlock Margin="0,8,0,0"
                           Text="{Binding Description}"
                           Style="{StaticResource BodyTextStyle}" />
            </StackPanel>

            <ItemsControl Grid.Row="1" Margin="0,20,0,0" ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="220" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:MetricTileViewModel}">
                        <controls:MetricTileControl Margin="0,0,14,14"
                                                    Label="{Binding Label}"
                                                    Value="{Binding Value}"
                                                    Trend="{Binding Trend}"
                                                    TrendDirection="{Binding TrendDirection}"
                                                    IsLoading="{Binding IsLoading}"
                                                    IsEmpty="{Binding IsEmpty}"
                                                    EmptyMessage="{Binding EmptyMessage}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <controls:CardControl Grid.Row="2"
                                  Margin="0,8,0,0"
                                  Header="{Binding EmptyStateTitle}"
                                  Subheader="Primary content region"
                                  EmptyMessage="{Binding EmptyStateBody}"
                                  IsLoading="{Binding IsLoading}"
                                  IsEmpty="{Binding IsEmpty}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,14"
                            Padding="14"
                            CornerRadius="10"
                            Background="{StaticResource PanelMutedBackgroundBrush}"
                            BorderBrush="{StaticResource PanelOutlineBrush}"
                            BorderThickness="1">
                        <TextBlock Text="This reusable Card wraps workspace content and centralizes loading/empty visuals. Envelope tiles below are reusable controls with hover/focus/selected states."
                                   Style="{StaticResource BodyTextStyle}" />
                    </Border>

                    <StackPanel Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Envelopes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="220" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:EnvelopeTileViewModel}">
                                    <controls:EnvelopeTileControl EnvelopeName="{Binding Name}"
                                                                  MonthlyBudget="{Binding MonthlyBudget}"
                                                                  CurrentBalance="{Binding CurrentBalance}"
                                                                  IsSelected="{Binding IsSelected}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ListBox Margin="0,4,0,0"
                                 ItemsSource="{Binding Transactions}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Focusable" Value="False" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:TransactionRowViewModel}">
                                    <controls:TransactionRowControl Date="{Binding Date}"
                                                                    Merchant="{Binding Merchant}"
                                                                    Amount="{Binding Amount}"
                                                                    Envelope="{Binding Envelope}"
                                                                    Category="{Binding Category}"
                                                                    IsSelected="{Binding IsSelected}"
                                                                    IsEdited="{Binding IsEdited}"
                                                                    IsFlagged="{Binding IsFlagged}"
                                                                    EditCommand="{Binding EditCommand}"
                                                                    SplitCommand="{Binding SplitCommand}"
                                                                    CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>
            </controls:CardControl>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:AccountsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Accounts" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Connected account balances and source-of-truth list."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Content="Reload"
                        Command="{Binding LoadCommand}" />
                <Button Grid.Column="2"
                        VerticalAlignment="Center"
                        Content="Add Account"
                        Command="{Binding AddAccountPlaceholderCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <controls:CardControl Grid.Row="2"
                                  Margin="0,12,0,0"
                                  Header="Account List"
                                  Subheader="Scaffold with API-bound loading and error handling"
                                  EmptyMessage="No accounts found for this family yet."
                                  IsLoading="{Binding IsLoading}"
                                  IsEmpty="{Binding IsEmpty}">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:AccountListItemViewModel}">
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        CornerRadius="10"
                                        Background="{StaticResource PanelMutedBackgroundBrush}"
                                        BorderBrush="{StaticResource PanelOutlineBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Type}" Style="{StaticResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Balance}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Foreground="{StaticResource PrimaryTextBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding PlaceholderMessage}"
                               Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>
            </controls:CardControl>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:TransactionsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Transactions" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Transaction feed with account scope, filtering, and sorting."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <ComboBox Grid.Column="1"
                          Margin="12,0,8,0"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                          DisplayMemberPath="Name" />
                <TextBox Grid.Column="2"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         Text="{Binding MerchantFilter, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="3"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         Text="{Binding CategoryFilter, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="4"
                        VerticalAlignment="Center"
                        Content="Reload"
                        Command="{Binding ReloadTransactionsCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <controls:CardControl Grid.Row="2"
                                  Margin="0,12,0,0"
                                  Header="Transaction Grid"
                                  Subheader="{Binding SortIndicator}"
                                  EmptyMessage="No transactions match current filters."
                                  IsLoading="{Binding IsLoading}"
                                  IsEmpty="{Binding IsEmpty}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Button Margin="0,0,8,0"
                                Content="Sort Date"
                                Command="{Binding SortByCommand}"
                                CommandParameter="Date" />
                        <Button Margin="0,0,8,0"
                                Content="Sort Merchant"
                                Command="{Binding SortByCommand}"
                                CommandParameter="Merchant" />
                        <Button Margin="0,0,8,0"
                                Content="Sort Amount"
                                Command="{Binding SortByCommand}"
                                CommandParameter="Amount" />
                        <Button Margin="0,0,8,0"
                                Content="Sort Category"
                                Command="{Binding SortByCommand}"
                                CommandParameter="Category" />
                        <CheckBox VerticalAlignment="Center"
                                  Content="Include Uncategorized"
                                  IsChecked="{Binding IncludeUncategorized}" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              Margin="0,12,0,0"
                              ItemsSource="{Binding Transactions}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              RowHeight="34"
                              GridLinesVisibility="Horizontal"
                              Background="{StaticResource PanelMutedBackgroundBrush}"
                              BorderBrush="{StaticResource PanelOutlineBrush}"
                              BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding OccurredDateDisplay}" Width="110" />
                            <DataGridTextColumn Header="Merchant" Binding="{Binding Merchant}" Width="180" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Envelope" Binding="{Binding Envelope}" Width="140" />
                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryDisplay}" Width="140" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </controls:CardControl>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:EnvelopesViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Envelopes" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Create, edit, and archive spending envelopes."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Content="Reload"
                        Command="{Binding LoadCommand}" />
                <Button Grid.Column="2"
                        VerticalAlignment="Center"
                        Content="New Envelope"
                        Command="{Binding BeginCreateCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <controls:CardControl Grid.Column="0"
                                      Header="Envelope List"
                                      Subheader="Current balances and archived state"
                                      EmptyMessage="No envelopes exist yet."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="{Binding IsEmpty}">
                    <ListBox ItemsSource="{Binding Envelopes}"
                             SelectedItem="{Binding SelectedEnvelope, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:EnvelopeListItemViewModel}">
                                <Border Padding="12"
                                        CornerRadius="10"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource PanelMutedBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource PanelOutlineBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#2A3A61" />
                                                    <Setter Property="BorderBrush" Value="#4B669E" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   Style="{StaticResource BodyTextStyle}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding MonthlyBudgetDisplay}"
                                                   Style="{StaticResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CurrentBalanceDisplay}"
                                                   Style="{StaticResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding IsArchived, StringFormat=Archived: {0}}"
                                                   Style="{StaticResource CaptionTextStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </controls:CardControl>

                <controls:CardControl Grid.Column="2"
                                      Header="{Binding EditorTitle}"
                                      Subheader="Create and maintain envelope details"
                                      EmptyMessage="Select an envelope to edit."
                                      IsLoading="{Binding IsLoading}"
                                      IsEmpty="False">
                    <StackPanel>
                        <TextBlock Text="{Binding EditorMessage}" Style="{StaticResource CaptionTextStyle}" />

                        <TextBlock Margin="0,14,0,6" Text="Name" Style="{StaticResource CaptionTextStyle}" />
                        <TextBox Text="{Binding DraftName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,14,0,6" Text="Monthly Budget" Style="{StaticResource CaptionTextStyle}" />
                        <TextBox Text="{Binding DraftMonthlyBudget, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" />

                        <CheckBox Margin="0,14,0,0"
                                  Content="Archived"
                                  IsChecked="{Binding DraftIsArchived}" />

                        <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Content="Save"
                                    Command="{Binding SaveCommand}" />
                            <Button Margin="0,0,8,0"
                                    Content="Archive"
                                    Command="{Binding ArchiveCommand}" />
                            <Button Content="Cancel"
                                    Command="{Binding CancelEditCommand}" />
                        </StackPanel>
                    </StackPanel>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:ReportsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Reports" Style="{StaticResource DisplayTextStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Reporting summaries with filter-ready endpoint bindings."
                               Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <TextBox Grid.Column="1"
                         Margin="12,0,8,0"
                         VerticalAlignment="Center"
                         Text="{Binding SelectedMonth, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Grid.Column="2"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          Content="Include Archived"
                          IsChecked="{Binding IncludeArchived}" />
                <Button Grid.Column="3"
                        VerticalAlignment="Center"
                        Content="Apply"
                        Command="{Binding ApplyFiltersCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="12"
                    CornerRadius="10"
                    Background="#4B311B"
                    BorderBrush="#A35D2F"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFD2A8" />
            </Border>

            <controls:CardControl Grid.Row="2"
                                  Margin="0,12,0,0"
                                  Header="Report Summary"
                                  Subheader="API-driven reporting scaffold"
                                  EmptyMessage="{Binding NoDataMessage}"
                                  IsLoading="{Binding IsLoading}"
                                  IsEmpty="{Binding IsEmpty}">
                <ItemsControl ItemsSource="{Binding SummaryTiles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemWidth="220" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:MetricTileViewModel}">
                            <controls:MetricTileControl Margin="0,0,14,14"
                                                        Label="{Binding Label}"
                                                        Value="{Binding Value}"
                                                        Trend="{Binding Trend}"
                                                        TrendDirection="{Binding TrendDirection}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </controls:CardControl>
        </Grid>
    </DataTemplate>

    <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Settings" Style="{StaticResource DisplayTextStyle}" />
                <TextBlock Margin="0,8,0,0"
                           Text="Session controls, profile placeholders, and runtime metadata."
                           Style="{StaticResource BodyTextStyle}" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:CardControl Grid.Row="0"
                                      Header="Session Controls"
                                      Subheader="Manage local desktop authentication state"
                                      EmptyMessage="Session controls unavailable."
                                      IsLoading="False"
                                      IsEmpty="False">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="{Binding SessionStatus}"
                                   Style="{StaticResource BodyTextStyle}" />
                        <Button Grid.Column="1"
                                Margin="12,0,8,0"
                                Content="Refresh Session"
                                Command="{Binding ReloadSessionCommand}" />
                        <Button Grid.Column="2"
                                Content="Sign Out"
                                Command="{Binding SignOutCommand}" />
                    </Grid>
                </controls:CardControl>

                <controls:CardControl Grid.Row="1"
                                      Margin="0,12,0,0"
                                      Header="Profile Preferences"
                                      Subheader="Placeholder controls for upcoming profile settings"
                                      EmptyMessage="{Binding ProfilePlaceholderMessage}"
                                      IsLoading="False"
                                      IsEmpty="False">
                    <StackPanel>
                        <TextBlock Text="{Binding ProfilePlaceholderMessage}" Style="{StaticResource CaptionTextStyle}" />
                        <TextBox Margin="0,8,0,0" Text="Display name (coming soon)" IsReadOnly="True" />
                        <TextBox Margin="0,8,0,0" Text="Default family (coming soon)" IsReadOnly="True" />
                    </StackPanel>
                </controls:CardControl>

                <controls:CardControl Grid.Row="2"
                                      Margin="0,12,0,0"
                                      Header="Application Metadata"
                                      Subheader="Current runtime configuration"
                                      EmptyMessage="Metadata unavailable."
                                      IsLoading="False"
                                      IsEmpty="False">
                    <StackPanel>
                        <TextBlock Text="{Binding EnvironmentName, StringFormat=Environment: {0}}" Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding AppVersion, StringFormat=Desktop Version: {0}}"
                                   Style="{StaticResource CaptionTextStyle}" />
                    </StackPanel>
                </controls:CardControl>
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
