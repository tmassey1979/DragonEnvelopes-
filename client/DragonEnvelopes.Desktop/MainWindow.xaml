<Window x:Class="DragonEnvelopes.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DragonEnvelopes.Desktop.Controls"
        xmlns:viewModels="clr-namespace:DragonEnvelopes.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="DragonEnvelopes"
        Width="1280"
        Height="800"
        MinWidth="1024"
        MinHeight="640"
        Background="{StaticResource ShellBackgroundBrush}">
    <Window.DataContext>
        <viewModels:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#F5F5F7" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelMutedBackgroundBrush" Color="#F6F6F7" />
        <SolidColorBrush x:Key="PanelOutlineBrush" Color="#D6D6D9" />
        <SolidColorBrush x:Key="AccentBrush" Color="#C91515" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#F8E2E2" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#171717" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#555555" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="74" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource PanelOutlineBrush}"
                BorderThickness="0,0,1,0"
                Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Image Width="190"
                           Height="78"
                           Stretch="Uniform"
                           Source="/Assets/dragonenvelopes-logo-transparent.png" />
                    <TextBlock Text="DragonEnvelopes" Style="{StaticResource HeadingTextStyle}" FontSize="26" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Family Budget Workspace"
                               Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              Margin="0,32,0,0"
                              ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:SidebarItemControl Glyph="{Binding Glyph}"
                                                         Label="{Binding Label}"
                                                         IsSelected="{Binding IsSelected}"
                                                         IsEnabled="{Binding IsEnabled}"
                                                         Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="2"
                        Padding="12"
                        CornerRadius="10"
                        Background="{StaticResource PanelMutedBackgroundBrush}"
                        BorderBrush="{StaticResource PanelOutlineBrush}"
                        BorderThickness="1">
                    <TextBlock Text="Sidebar and topbar stay fixed while main content swaps by binding."
                               Style="{StaticResource CaptionTextStyle}" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Background="{StaticResource ShellBackgroundBrush}"
                BorderBrush="{StaticResource PanelOutlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TopBarTitle}" Style="{StaticResource HeadingTextStyle}" FontSize="24" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding TopBarSubtitle}"
                               Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="16,0,8,0"
                           VerticalAlignment="Center"
                           Text="Family:"
                           Style="{StaticResource CaptionTextStyle}" />

                <ComboBox Grid.Column="2"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center"
                         Width="220"
                         ItemsSource="{Binding AvailableFamilies}"
                         SelectedItem="{Binding SelectedFamily, Mode=TwoWay}"
                         DisplayMemberPath="Name"
                         AutomationProperties.Name="Active family selector" />

                <TextBlock Grid.Column="3"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center"
                           Text="{Binding AuthStatus}"
                           Style="{StaticResource CaptionTextStyle}" />

                <TextBlock Grid.Column="4"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center"
                           Text="{Binding RoleSummary}"
                           Style="{StaticResource CaptionTextStyle}" />

                <Button Grid.Column="5"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        MinWidth="92"
                        Content="{Binding AuthActionLabel}"
                        AutomationProperties.Name="Authentication action"
                        Click="OnAuthButtonClicked" />

                <Button Grid.Column="6"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        MinWidth="84"
                        Content="Ping API"
                        AutomationProperties.Name="Ping backend API"
                        Command="{Binding PingApiCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1">
            <Border Padding="24">
                <ContentControl Content="{Binding CurrentContent}" />
            </Border>

            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,16,16"
                    Width="340"
                    MaxHeight="360"
                    CornerRadius="10"
                    BorderBrush="{StaticResource PanelOutlineBrush}"
                    BorderThickness="1"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    Padding="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding OperationStatusCenter.HasToasts}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding OperationStatusCenter.HasActiveOperations}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding OperationStatusCenter.ActiveOperationSummary}"
                                   Style="{StaticResource CaptionTextStyle}" />

                        <Button Grid.Column="1"
                                Padding="8,2"
                                Content="Clear"
                                Command="{Binding ClearOperationToastsCommand}" />
                    </Grid>

                    <ScrollViewer Margin="0,8,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="280">
                        <ItemsControl ItemsSource="{Binding OperationStatusCenter.Toasts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Padding="8"
                                            CornerRadius="8"
                                            BorderBrush="{Binding LevelBrush}"
                                            BorderThickness="1"
                                            Background="{StaticResource PanelMutedBackgroundBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding LevelLabel}"
                                                           Style="{StaticResource CaptionTextStyle}"
                                                           Foreground="{Binding LevelBrush}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding Message}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource CaptionTextStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    Padding="6,0"
                                                    Content="x"
                                                    Command="{Binding DataContext.DismissOperationToastCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
